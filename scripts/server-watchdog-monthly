#!/usr/bin/env python3
"""Entry point: run the monthly maintenance report and send it via email."""

import argparse
import sys

from server_watchdog.config import Config
from server_watchdog.email_sender import send_email
from server_watchdog.logging_setup import setup_logging
from server_watchdog.maintenance import build_report


def main():
    parser = argparse.ArgumentParser(
        description="Run the monthly maintenance report and send it via email."
    )
    parser.add_argument(
        "--no-fallback",
        action="store_true",
        help="Wait for rate limits instead of falling back to a lower model.",
    )
    args = parser.parse_args()

    config = Config()
    setup_logging(config)

    # Apply --no-fallback override
    if args.no_fallback:
        config._parser.set("llm", "no_fallback", "true")

    import socket  # pylint: disable=import-outside-toplevel
    hostname = socket.getfqdn()

    cfg_status = "found" if config.config_file_found else "NOT FOUND – using defaults"
    print(f"Config: {config.config_path} ({cfg_status})", flush=True)
    if not config.config_file_found:
        print(
            "  WARNING: Config file not found. "
            "Create it at the path above or set WATCHDOG_CONFIG.",
            flush=True,
        )

    print("Running maintenance checks…", flush=True)
    plain, html = build_report(config)

    subject = f"Monthly Maintenance Report – {hostname}"

    print("Sending email…", flush=True)
    try:
        send_email(config, subject, plain, html)
        print("✓ Email sent successfully.", flush=True)
    except Exception as exc:  # pylint: disable=broad-except
        print(f"ERROR: Failed to send monthly report: {exc}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
