#!/usr/bin/env python3
"""Entry point: run the real-time AVC denial monitor daemon."""

import sys

from server_watchdog.avc_monitor import main as run_monitor
from server_watchdog.config import Config
from server_watchdog.logging_setup import setup_logging


def main():
    config = Config()
    setup_logging(config)
    run_monitor(config)


if __name__ == "__main__":
    main()
