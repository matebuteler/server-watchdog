#!/usr/bin/env python3
"""Entry point: take one bottleneck sample and append it to the data file.

Intended to be called every few minutes by server-watchdog-sampler.timer.
Each run records a compact JSON line containing CPU, IO-wait, memory, and
swap percentages measured over a short sampling window.
"""

import sys

from server_watchdog.bottleneck import DEFAULT_DATA_FILE, DEFAULT_SAMPLE_INTERVAL, take_sample
from server_watchdog.config import Config
from server_watchdog.logging_setup import setup_logging


def main():
    config = Config()
    setup_logging(config)

    data_file = config.get(
        "maintenance", "bottleneck_data_file", fallback=DEFAULT_DATA_FILE
    )
    sample_interval = config.getint(
        "maintenance", "bottleneck_sample_interval_seconds",
        fallback=DEFAULT_SAMPLE_INTERVAL,
    )
    try:
        take_sample(data_file=data_file, sample_interval=sample_interval)
    except OSError as exc:
        print(
            f"server-watchdog-sampler: failed to write sample to {data_file!r}: {exc}",
            file=sys.stderr,
        )
        sys.exit(1)


if __name__ == "__main__":
    main()
